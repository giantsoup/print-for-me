{
    "name": "print-for-me",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": "^24.14.0",
        "npm": "^11.0.0"
    },
    "scripts": {
        "build": "vite build",
        "build:ssr": "vite build && vite build --ssr",
        "dev": "vite",
